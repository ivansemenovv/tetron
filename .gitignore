*.tgz

# Yarn Integrity file
.yarn-integrity

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# CocoaPods
ios/Pods/
ios/Podfile.lock

# Temporary files
*.tmp
*.temp
.tmp/
.temp/
