{
  "name": "tetron",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "windows": "react-native run-windows",
    "start": "react-native start",
    "test": "jest",
    "lint": "eslint .",
    "build:ios": "cd ios && xcodebuild -workspace Tetron.xcworkspace -scheme Tetron -configuration Release -destination generic/platform=iOS -archivePath ./build/Tetron.xcarchive archive",
    "export:ios": "cd ios && xcodebuild -exportArchive -archivePath ./build/Tetron.xcarchive -exportPath ./build -exportOptionsPlist ./ExportOptions.plist"
  },
  "dependencies": {
    "react": "18.2.0",
    "react-native": "0.73.2",
    "react-native-orientation-locker": "^1.5.0",
    "react-native-vector-icons": "^10.0.3",
    "@react-native-async-storage/async-storage": "^1.21.0",
    "react-native-haptic-feedback": "^2.2.0",
    "react-native-sound": "^0.11.2"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@babel/preset-env": "^7.20.0",
    "@babel/runtime": "^7.20.0",
    "@react-native/eslint-config": "^0.73.1",
    "@react-native/metro-config": "^0.73.2",
    "@react-native/typescript-config": "^0.73.1",
    "@types/react": "^18.2.6",
    "@types/react-test-renderer": "^18.0.0",
    "babel-jest": "^29.6.3",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "metro-react-native-babel-preset": "0.76.8",
    "prettier": "^2.8.8",
    "react-test-renderer": "18.2.0",
    "typescript": "4.9.4"
  },
  "engines": {
    "node": ">=18"
  },
  "react-native": {
    "react-native-vector-icons/AntDesign": "react-native-vector-icons/lib/ant-design",
    "react-native-vector-icons/Entypo": "react-native-vector-icons/lib/entypo",
    "react-native-vector-icons/EvilIcons": "react-native-vector-icons/lib/evil-icons",
    "react-native-vector-icons/Feather": "react-native-vector-icons/lib/feather",
    "react-native-vector-icons/FontAwesome": "react-native-vector-icons/lib/font-awesome",
    "react-native-vector-icons/Foundation": "react-native-vector-icons/lib/foundation",
    "react-native-vector-icons/Ionicons": "react-native-vector-icons/lib/ionicons",
    "react-native-vector-icons/MaterialIcons": "react-native-vector-icons/lib/material-icons",
    "react-native-vector-icons/MaterialCommunityIcons": "react-native-vector-icons/lib/material-community-icons",
    "react-native-vector-icons/Octicons": "react-native-vector-icons/lib/octicons",
    "react-native-vector-icons/Zocial": "react-native-vector-icons/lib/zocial",
    "react-native-vector-icons/SimpleLineIcons": "react-native-vector-icons/lib/simple-line-icons"
  },
  "description": "A classic Tetris game built with React Native for iOS and Windows, with automated builds via GitHub Actions and TestFlight distribution.",
  "main": "index.js",
  "keywords": [],
  "author": "",
  "license": "ISC"
}
